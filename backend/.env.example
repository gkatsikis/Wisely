# Copy to .env and adjust. docker-compose reads these (with the defaults shown).
# .env is gitignored — never commit real secrets.

DEBUG=1
SECRET_KEY=django-insecure-dev-key-change-me

POSTGRES_DB=wisely
POSTGRES_USER=wisely
POSTGRES_PASSWORD=wisely

# Optional — raises Google Books rate limits. Leave blank to call unauthenticated.
GOOGLE_BOOKS_API_KEY=
# Cover resolution policy: 'auto' or 'openlibrary_only'
BOOK_COVER_POLICY=auto

# Affiliate program IDs (optional) — used to generate book buy-links
BOOKSHOP_AFFILIATE_ID=
AMAZON_ASSOCIATE_TAG=

# Google OAuth (django-allauth social login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/auth/google/callback

# CORS — comma-separated origins allowed to call the API (defaults to the Next.js dev server)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email — dev uses the console backend (prints to terminal) by default.
# For production, uncomment and fill these so verification emails actually send:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Wisely <no-reply@wisely.local>
